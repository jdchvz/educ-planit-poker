# Node Environment
NODE_ENV=production

# Redis URL (optional - falls back to in-memory storage if not set)
# Example: redis://localhost:6379
# For Redis Cloud: redis://user:password@host:port
REDIS_URL=

# Socket.io URL (for production deployment)
NUXT_PUBLIC_SOCKET_URL=https://your-domain.up.railway.app

# Formspree ID for feedback widget
NUXT_PUBLIC_FORMSPREE_ID=your-formspree-id
